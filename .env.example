ANTHROPIC_API_KEY=your_anthropic_api_key
OPENAI_API_KEY=your_openai_api_key
OPENCLAW_GATEWAY_TOKEN=replace_with_a_long_random_token
OPENCLAW_GATEWAY_URL=ws://openclaw:18789
NEXT_PUBLIC_APP_URL=http://localhost:3000

OPENCLAW_AUTO_APPROVE_PENDING_DEVICES=true
OPENCLAW_AUTO_APPROVE_TIMEOUT_MS=1000

OPENCLAW_PREPAIR_ON_START=true
OPENCLAW_PREPAIR_STRICT=true
OPENCLAW_PREPAIR_MAX_WAIT_MS=60000
OPENCLAW_PREPAIR_RETRY_DELAY_MS=3000
OPENCLAW_PREPAIR_CONNECT_TIMEOUT_MS=8000
